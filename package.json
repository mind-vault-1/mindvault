{
  "name": "mindvault",
  "version": "1.0.0",
  "private": true,
  "description": "Payment-protected vault for digital resources on Stellar, using HTTP 402 + the x402 protocol",
  "packageManager": "pnpm@10.28.2",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev:server": "pnpm --filter @mindvault/server dev",
    "dev:web": "pnpm --filter @mindvault/web dev",
    "build:registry-client": "pnpm --filter @mindvault/registry-client build",
    "build:server": "pnpm run build:registry-client && pnpm --filter @mindvault/server build",
    "db:generate": "pnpm --filter @mindvault/server db:generate",
    "db:migrate": "pnpm --filter @mindvault/server db:migrate",
    "generate-wallet": "pnpm --filter @mindvault/server generate-wallet",
    "contract:build": "stellar contract build --manifest-path contract/Cargo.toml",
    "contract:test": "cargo test --manifest-path contract/Cargo.toml",
    "contract:bindings": "node scripts/generate-bindings.mjs",
    "docs:links": "node scripts/check-doc-links.mjs",
    "lint": "pnpm exec eslint \"server/src/**/*.{ts,tsx}\" \"web/src/**/*.{ts,tsx}\" \"packages/**/*.{ts,tsx}\" \"mcp/src/**/*.{ts,tsx}\"",
    "format:check": "pnpm exec prettier --check \"server/**/*.{ts,tsx,js,json,md}\" \"web/**/*.{ts,tsx,js,json,md}\" \"packages/**/*.{ts,tsx,js,json,md}\" \"mcp/**/*.{ts,tsx,js,json,md}\"",
    "test": "pnpm run build:registry-client && pnpm --filter @mindvault/registry-client test && pnpm --filter @mindvault/server test && pnpm --filter @mindvault/web test && pnpm --filter @mindvault/mcp test",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,cjs,mjs,json,md}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-prettier": "^5.5.6",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "markdown-link-check": "^3.14.2",
    "prettier": "^3.8.4",
    "supertest": "^6.3.4"
  },
  "keywords": [
    "x402",
    "stellar",
    "soroban",
    "marketplace",
    "ai-agents",
    "micropayments"
  ],
  "license": "MIT",
  "pnpm": {
    "overrides": {
      "axios": "^1.16.0",
      "ws": "^8.21.0",
      "fast-xml-parser": "^4.4.1",
      "minimatch": "^9.0.7",
      "esbuild": "^0.25.0",
      "hono": "^4.12.25",
      "@opentelemetry/sdk-node": "^0.217.0",
      "@opentelemetry/core": "^2.8.0",
      "protobufjs": "^8.4.1"
    }
  }
}
