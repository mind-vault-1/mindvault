{
  "name": "@mindvault/registry-client",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "TypeScript client for the MindVault vault-registry Soroban contract on Stellar.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
